{
  "cases": [
    {
      "id": "LS-001",
      "tags": ["solvable", "baseline"],
      "expect": "solve",
      "matrix": [[2, 1, -1], [-3, -1, 2], [-2, 1, 2]],
      "vector": [8, -11, -3],
      "expected_solution": [2, 3, -1]
    },
    {
      "id": "LS-002",
      "tags": ["solvable", "near-singular"],
      "expect": "solve",
      "matrix": [[1, 1, 1], [1, 1.0001, 1], [1, 1, 1.0002]],
      "vector": [3, 3.0001, 3.0002],
      "expected_solution": [1, 1, 1]
    },
    {
      "id": "LS-003",
      "tags": ["singular", "edge"],
      "expect": "singular",
      "matrix": [[1, 2, 3], [2, 4, 6], [1, 1, 1]],
      "vector": [6, 12, 3],
      "expected_solution": []
    },
    {
      "id": "LS-004",
      "tags": ["dimension-mismatch", "edge"],
      "expect": "solve",
      "matrix": [[3, 2], [1, 4]],
      "vector": [7, 9],
      "expected_solution": [1, 2]
    }
  ]
}
